{
  "name": "@jhlagado/glimmer",
  "version": "0.5.3",
  "description": "Glimmer: a reactive Z80 game framework compiling to readable AZM — state cells, cards, routines, layout types, and source-level Debug80 maps",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./build": {
      "types": "./dist/src/build.d.ts",
      "import": "./dist/src/build.js"
    },
    "./cli": {
      "types": "./dist/src/cli.d.ts",
      "import": "./dist/src/cli.js"
    },
    "./package.json": "./package.json"
  },
  "types": "dist/src/index.d.ts",
  "bin": {
    "glimmer": "dist/src/cli.js"
  },
  "files": [
    "dist/src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhlagado/glimmer.git"
  },
  "keywords": [
    "z80",
    "azm",
    "preprocessor",
    "game-engine",
    "tec-1g",
    "retro",
    "8-bit"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "glimmer": "npm run build && node dist/src/cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@jhlagado/azm": "^0.3.4"
  }
}
