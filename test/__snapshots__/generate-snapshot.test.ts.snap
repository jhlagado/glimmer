exports[`generated output snapshots > tetro.glim generates byte-identical output 1`] = `
"; Generated by Glimmer from program Tetro.
; Do not edit: regenerate from the Glimmer source.
;
; Register contracts are declared with .routine and checked by
; AZM at strict strength (mon3 register profile) during the
; Glimmer build.

        .org    $4000

; Register contracts are declared with .routine and checked at
; strict strength over this whole generated file.
        .contracts strict

; --- TEC-1G / MON-3 platform ---
ApiScanKeys       .equ 16
ApiRandom         .equ 49   ; A = random byte, destroys B
PortDigits        .equ $01
PortSegs          .equ $02
PortRow           .equ $05
PortRed           .equ $06
PortGreen         .equ $F8
PortBlue          .equ $F9
SpeakerBit        .equ $80
ScanDwellPeriod   .equ 255
COLOR_RED         .equ $01
COLOR_GREEN       .equ $02
COLOR_BLUE        .equ $04
COLOR_YELLOW      .equ COLOR_RED + COLOR_GREEN
COLOR_CYAN        .equ COLOR_GREEN + COLOR_BLUE
COLOR_MAGENTA     .equ COLOR_RED + COLOR_BLUE
COLOR_WHITE       .equ $07

; --- MON-3 LCD (board hardware) ---
ApiStringToLcd    .equ 13   ; HL = string; destroys A,HL
ApiCharToLcd      .equ 14   ; A = character
ApiCommandToLcd   .equ 15   ; B = instruction byte
LcdRow1           .equ $80
LcdRow2           .equ $C0
LcdRow3           .equ $94
LcdRow4           .equ $D4

; --- MON-3 key codes ---
KEY_4             .equ $04
KEY_6             .equ $06
KEY_2             .equ $02
