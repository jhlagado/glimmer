        .db     2,1,2,1
        .db     2,1,2,1
        .db     2,1,2,1
        .db     2,1,2,1
        .db     2,1,2,1
ShapeRotColorTbl:
        .db     COLOR_CYAN
        .db     COLOR_WHITE
        .db     COLOR_MAGENTA
        .db     COLOR_GREEN
        .db     COLOR_RED
        .db     COLOR_BLUE
        .db     COLOR_YELLOW
ShapeId_PieceI    .equ 0
ShapeId_PieceO    .equ 1
ShapeId_PieceT    .equ 2
ShapeId_PieceS    .equ 3
ShapeId_PieceZ    .equ 4
ShapeId_PieceJ    .equ 5
ShapeId_PieceL    .equ 6
ShapeRotCount     .equ 7

; --- HUD data tables ---
HudMaskTbl:
        .db     $20, $10, $08, $04, $02, $01
HudGlyphTbl:
        .db     $EB, $28, $CD, $AD, $2E, $A7, $E7, $29
        .db     $EF, $2F, $6F, $E6, $C3, $EC, $C7, $47

; --- runtime loop ---
Start:
        call    FbClear
        call    HudBlankDig
MainLoop:
        call    ScanFrame            ; show one full frame, then blank
        call    GlimPollBindings     ; game work runs in the blank window
        ld      a,(CurrentCard)    ; latch: card transitions land at
        ld      (GlimActiveCard),a  ; frame start, never mid-frame
        call    GlimTickTimers
        call    GlimRunDeriveEffects
        call    GlimMergeRaised
        call    GlimRunLogicEffects
        call    GlimMergeRaised
        call    GlimRunRenderEffects
        call    GlimEndFrame
        jp      MainLoop

; --- input polling (MON-3 _scanKeys) ---
.routine
GlimPollBindings:
        ld      c,ApiScanKeys
        rst     $10
        jr      z,_keydown
        ld      a,$FF                ; no key: disarm autorepeat
        ld      (Glim_HeldKey),a
        ret
_keydown:
        ld      b,a                  ; B = key code (DE unsafe: matrix kbd)
        jr      c,_newpress
        ld      a,(Glim_HeldKey)     ; held: autorepeat armed for this key?
        cp      b
        ret     nz
        ld      a,(Glim_HeldCount)
        dec     a
        ld      (Glim_HeldCount),a
        ret     nz
        ld      a,b
        cp      KEY_4
        jr      nz,_held_MoveLeftP_KEY_4
        ld      a,10
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (MoveLeftP),a
        ld      a,(Changed1)
        or      CHG_MOVELEFTP
        ld      (Changed1),a
        ret
_held_MoveLeftP_KEY_4:
        ld      a,b
        cp      KEY_6
        jr      nz,_held_MoveRightP_KEY_6
        ld      a,10
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (MoveRightP),a
        ld      a,(Changed1)
        or      CHG_MOVERIGHTP
        ld      (Changed1),a
        ret
_held_MoveRightP_KEY_6:
        ld      a,b
        cp      KEY_2
        jr      nz,_held_SoftDropP_KEY_2
        ld      a,3
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (SoftDropP),a
        ld      a,(Changed1)
        or      CHG_SOFTDROPP
        ld      (Changed1),a
        ret
_held_SoftDropP_KEY_2:
        ret
_newpress:
        ld      a,1                  ; any key
        ld      (AnyKeyP),a
        ld      a,(Changed2)
        or      CHG_ANYKEYP
        ld      (Changed2),a
        ld      a,b
        cp      KEY_4
        jr      nz,_new_MoveLeftP_KEY_4
        ld      a,b                  ; arm autorepeat
        ld      (Glim_HeldKey),a
        ld      a,10
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (MoveLeftP),a
        ld      a,(Changed1)
        or      CHG_MOVELEFTP
        ld      (Changed1),a
        ret
_new_MoveLeftP_KEY_4:
        ld      a,b
        cp      KEY_6
        jr      nz,_new_MoveRightP_KEY_6
        ld      a,b                  ; arm autorepeat
        ld      (Glim_HeldKey),a
        ld      a,10
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (MoveRightP),a
        ld      a,(Changed1)
        or      CHG_MOVERIGHTP
        ld      (Changed1),a
        ret
_new_MoveRightP_KEY_6:
        ld      a,b
        cp      KEY_2
        jr      nz,_new_SoftDropP_KEY_2
        ld      a,b                  ; arm autorepeat
        ld      (Glim_HeldKey),a
        ld      a,3
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (SoftDropP),a
        ld      a,(Changed1)
        or      CHG_SOFTDROPP
        ld      (Changed1),a
        ret
_new_SoftDropP_KEY_2:
        ld      a,b
        cp      KEY_5
        jr      nz,_new_RotateP_KEY_5
        ld      a,1
        ld      (RotateP),a
        ld      a,(Changed2)
        or      CHG_ROTATEP
        ld      (Changed2),a
        ret
_new_RotateP_KEY_5:
        ld      a,b
        cp      KEY_AD
        jr      nz,_new_RotateP_KEY_AD
        ld      a,1
        ld      (RotateP),a
        ld      a,(Changed2)
        or      CHG_ROTATEP
        ld      (Changed2),a
        ret
_new_RotateP_KEY_AD:
        ld      a,b
        cp      KEY_0
        jr      nz,_new_PauseP_KEY_0
        ld      a,1
        ld      (PauseP),a
        ld      a,(Changed2)
        or      CHG_PAUSEP
        ld      (Changed2),a
        ret
_new_PauseP_KEY_0:
        ret

; --- timers, ramps, frame counter ---
.routine
GlimTickTimers:
        ld      a,(FrameCount)
        inc     a
        ld      (FrameCount),a
        ld      a,(Changed2)
        or      CHG_FRAMECOUNT
        ld      (Changed2),a
        ld      a,(Glim_Gravity_cnt)
        dec     a
        ld      (Glim_Gravity_cnt),a
        jr      nz,_next_Gravity
        ld      a,(Gravity)       ; reload from period cell
        ld      (Glim_Gravity_cnt),a
        ld      a,1
        ld      (GravityFire),a
        ld      a,(Changed2)
        or      CHG_GRAVITYFIRE
        ld      (Changed2),a
_next_Gravity:
        ld      a,(ClearHold)
        or      a
        jr      z,_next_ClearHold            ; idle
        dec     a
        ld      (ClearHold),a
        jr      nz,_next_ClearHold
        ld      a,1
        ld      (ClearTick),a
        ld      a,(Changed2)
        or      CHG_CLEARTICK
        ld      (Changed2),a
_next_ClearHold:
        ld      hl,(GOverGate)
        ld      a,h
        or      l
        jr      z,_next_GOverGate            ; idle
        dec     hl
        ld      (GOverGate),hl
        ld      a,h
        or      l
        jr      nz,_next_GOverGate
        ld      a,1
        ld      (GateOpenP),a
        ld      a,(Changed2)
        or      CHG_GATEOPENP
        ld      (Changed2),a
_next_GOverGate:
        ret

; --- derive phase dispatch ---
.routine
GlimRunDeriveEffects:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_DifficultyCurve
        ld      a,(Changed0)
        and     GlimDep_DifficultyCurve__B0
        jr      z,_skip_DifficultyCurve
        call    Glim_DifficultyCurve
_skip_DifficultyCurve:
        ret

; --- logic phase dispatch ---
.routine
GlimRunLogicEffects:
        ld      a,(GlimActiveCard)
        cp      Card.Splash
        jr      nz,_skip_SplashShow
        ld      a,(GlimPrevCard)
        cp      Card.Splash
        jr      z,_skip_SplashShow
        ld      a,(Changed2)
        and     GlimDep_SplashShow__B2
        jr      z,_skip_SplashShow
        call    Glim_SplashShow
_skip_SplashShow:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_StartRound
        ld      a,(GlimPrevCard)
        cp      Card.Playing
        jr      z,_skip_StartRound
        ld      a,(Changed2)
        and     GlimDep_StartRound__B2
        jr      z,_skip_StartRound
        call    Glim_StartRound
_skip_StartRound:
        ld      a,(GlimActiveCard)
        cp      Card.Paused
        jr      nz,_skip_PausedShow
        ld      a,(GlimPrevCard)
        cp      Card.Paused
        jr      z,_skip_PausedShow
        ld      a,(Changed2)
        and     GlimDep_PausedShow__B2
        jr      z,_skip_PausedShow
        call    Glim_PausedShow
_skip_PausedShow:
        ld      a,(GlimActiveCard)
        cp      Card.GameOver
        jr      nz,_skip_GameOverShow
        ld      a,(GlimPrevCard)
        cp      Card.GameOver
        jr      z,_skip_GameOverShow
        ld      a,(Changed2)
        and     GlimDep_GameOverShow__B2
        jr      z,_skip_GameOverShow
        call    Glim_GameOverShow
_skip_GameOverShow:
        ld      a,(GlimActiveCard)
        ld      (GlimPrevCard),a
        ld      a,(GlimActiveCard)
        cp      Card.Splash
        jr      nz,_skip_SplashExit
        ld      a,(Changed2)
        and     GlimDep_SplashExit__B2
        jr      z,_skip_SplashExit
        call    Glim_SplashExit
_skip_SplashExit:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_ApplyMove
        ld      a,(Changed1)
        and     GlimDep_ApplyMove__B1
        jr      z,_skip_ApplyMove
        call    Glim_ApplyMove
_skip_ApplyMove:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_ApplyRotate
        ld      a,(Changed2)
        and     GlimDep_ApplyRotate__B2
        jr      z,_skip_ApplyRotate
        call    Glim_ApplyRotate
_skip_ApplyRotate:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_ApplyGravity
        ld      a,(Changed1)
        and     GlimDep_ApplyGravity__B1
        jr      nz,_run_ApplyGravity
        ld      a,(Changed2)
        and     GlimDep_ApplyGravity__B2
        jr      nz,_run_ApplyGravity
        jr      _skip_ApplyGravity
_run_ApplyGravity:
        call    Glim_ApplyGravity
_skip_ApplyGravity:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_FinishClear
        ld      a,(Changed2)
        and     GlimDep_FinishClear__B2
        jr      z,_skip_FinishClear
        call    Glim_FinishClear
_skip_FinishClear:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_Pause
        ld      a,(Changed2)
        and     GlimDep_Pause__B2
        jr      z,_skip_Pause
        call    Glim_Pause
_skip_Pause:
        ld      a,(GlimActiveCard)
        cp      Card.Paused
        jr      nz,_skip_Unpause
        ld      a,(Changed2)
        and     GlimDep_Unpause__B2
        jr      z,_skip_Unpause
        call    Glim_Unpause
_skip_Unpause:
        ld      a,(GlimActiveCard)
        cp      Card.GameOver
        jr      nz,_skip_OpenGate
        ld      a,(Changed2)
        and     GlimDep_OpenGate__B2
        jr      z,_skip_OpenGate
        call    Glim_OpenGate
_skip_OpenGate:
        ld      a,(GlimActiveCard)
        cp      Card.GameOver
        jr      nz,_skip_Restart
        ld      a,(Changed2)
        and     GlimDep_Restart__B2
        jr      z,_skip_Restart
        call    Glim_Restart
_skip_Restart:
        ret

; --- render phase dispatch ---
.routine
GlimRunRenderEffects:
        ld      a,(GlimActiveCard)
        cp      Card.Splash
        jr      nz,_skip_SplashTwinkle
        ld      a,(Changed2)
        and     GlimDep_SplashTwinkle__B2
        jr      z,_skip_SplashTwinkle
        call    Glim_SplashTwinkle
_skip_SplashTwinkle:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_ShowPreview
        ld      a,(Changed0)
        and     GlimDep_ShowPreview__B0
        jr      z,_skip_ShowPreview
        call    Glim_ShowPreview
_skip_ShowPreview:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_DrawBoard
        ld      a,(Changed0)
        and     GlimDep_DrawBoard__B0
        jr      nz,_run_DrawBoard
        ld      a,(Changed1)
        and     GlimDep_DrawBoard__B1
        jr      nz,_run_DrawBoard
        jr      _skip_DrawBoard
_run_DrawBoard:
        call    Glim_DrawBoard
_skip_DrawBoard:
        ld      a,(GlimActiveCard)
        cp      Card.Playing
        jr      nz,_skip_DrawScore
        ld      a,(Changed0)
        and     GlimDep_DrawScore__B0
        jr      z,_skip_DrawScore
        call    Glim_DrawScore
_skip_DrawScore:
        ld      a,(GlimActiveCard)
        cp      Card.GameOver
        jr      nz,_skip_GameOverPulse
        ld      a,(Changed2)
        and     GlimDep_GameOverPulse__B2
        jr      z,_skip_GameOverPulse
        call    Glim_GameOverPulse
_skip_GameOverPulse:
        ret

; --- phase boundary: deliver same-frame raises ---
.routine
GlimMergeRaised:
        ld      a,(Changed0)
        ld      b,a
        ld      a,(Raised0)
        or      b
        ld      (Changed0),a
        ld      a,(Changed1)
        ld      b,a
        ld      a,(Raised1)
        or      b
        ld      (Changed1),a
        ld      a,(Changed2)
        ld      b,a
        ld      a,(Raised2)
        or      b
        ld      (Changed2),a
        xor     a
        ld      (Raised0),a
        ld      (Raised1),a
        ld      (Raised2),a
        ret

; --- enter block SplashShow ---
.routine
Glim_SplashShow:
    call FbClear
    call HudBlankDig
    lcd_row MsgSplash, LcdRow1
        ret

; --- render block SplashTwinkle ---
.routine
Glim_SplashTwinkle:
    ; one random pixel per frame, wiped every 64 frames
    ld a,(FrameCount)
    and %00111111
    call z,FbClear
    ld c,ApiRandom
    rst $10             ; A = random byte
    ld e,a
    and %00000111
    ld b,a              ; column
    ld a,e
    rrca
    rrca
    rrca
    and %00000111
    ld c,a              ; row
    ld a,e
    rrca
    rrca
    and %00000111
    jr nz,_color
    ld a,COLOR_CYAN     ; colour 0 would be an invisible twinkle
_color:
    call FbPlot
        ret

; --- logic block SplashExit ---
.routine
Glim_SplashExit:
        ld      a,Card.Playing      ; goto Playing
        ld      (CurrentCard),a
        ld      a,(Next2)            ; a consumer already ran: defer to next frame
        or      CHG_CURRENTCARD
        ld      (Next2),a
        ret

; --- enter block StartRound ---
.routine
Glim_StartRound:
    lcd_row MsgRun, LcdRow1
    call InitGame
    call SpawnPiece      ; empty board: the spawn probe cannot block
        ld      a,(Raised0)          ; deliver to later phases this frame
        or      CHG_PLAYERX + CHG_PLAYERY + CHG_CURPIECEINDEX + CHG_CURROTATION + CHG_NEXTPIECEINDEX + CHG_LINESCLEARED + CHG_CLEARMASK
        ld      (Raised0),a
        ld      a,(Raised1)          ; deliver to later phases this frame
        or      CHG_BOARDROWS + CHG_BOARDRED + CHG_BOARDGREEN + CHG_BOARDBLUE
        ld      (Raised1),a
        ld      a,(Next0)            ; a consumer already ran: defer to next frame
        or      CHG_SCORE
        ld      (Next0),a
        ret

; --- render block ShowPreview ---
.routine
Glim_ShowPreview:
    lcd_row MsgNext, LcdRow2
    ld hl,PieceNames
    ld a,(NextPieceIndex)
    ld e,a
    ld d,0
    add hl,de
    ld a,(hl)
    ld c,ApiCharToLcd
    rst $10
        ret

; --- logic block ApplyMove ---
.routine
Glim_ApplyMove:
    ld a,(PlayerX)
    ld d,a
    ld a,(MoveLeftP)
    or a
    jr z,_right
    dec d                ; left
    jr _probe
_right:
    inc d
_probe:
    ld a,d
    cp 8                 ; underflow wraps past 8 too (unsigned)
    jr nc,_done
    ld a,(PlayerY)
    ld e,a
    call CheckCollAt
    jr c,_done
    ld a,d
    ld (PlayerX),a
_done:
        ld      a,(Raised0)          ; deliver to later phases this frame
        or      CHG_PLAYERX
        ld      (Raised0),a
        ret

; --- logic block ApplyRotate ---
.routine
Glim_ApplyRotate:
    ld a,(CurRotation)
    ld b,a               ; keep the old rotation for the revert
    inc a
    and %00000011
    ld (CurRotation),a
    push bc
    call SetCurPiece
    pop bc
    ld a,(PlayerX)
    ld d,a
    ld a,(PlayerY)
    ld e,a
    call CheckCollAt
    jr nc,_ok
    ld a,b               ; blocked: restore the old rotation
    ld (CurRotation),a
    call SetCurPiece
    jr _done
_ok:
    call Snd_Rotate
_done:
        ld      a,(Raised0)          ; deliver to later phases this frame
        or      CHG_CURROTATION
        ld      (Raised0),a
        ret

; --- logic block ApplyGravity ---
.routine
Glim_ApplyGravity:
    ld a,(ClearMask)     ; rows mid-flash: gravity holds
    or a
    jp nz,_done
    ld a,(PlayerX)
    ld d,a
    ld a,(PlayerY)
    inc a
    ld e,a
    call CheckCollAt
    jr c,_lock
    ld a,e               ; free: descend
    ld (PlayerY),a
    jp _done
_lock:
    call LockPiece
    call Snd_Lock
    call FullRowsMask    ; A = bitmask of full rows
    or a
    jr z,_spawn
    ld (ClearMask),a     ; flash first; FinishClear collapses on the tick
    ld a,200
    ld (PlayerY),a       ; park the locked piece off the draw overlay
    ld a,24              ; arm the hold timer (corpus LineClearHold)
    ld (ClearHold),a
    call Snd_Clear
    jp _done
_spawn:
    call SpawnPiece
    jr nc,_done          ; spawn blocked: the stack reached the top
    ; conditional navigation: goto is unconditional once a block runs,
    ; so a conditional transition writes CurrentCard directly (declared
    ; in updates). Enter blocks are edge-triggered, so the every-run
    ; change mark cannot re-run them.
    ld a,Card.GameOver
    ld (CurrentCard),a
_done:
        ld      a,(Raised0)          ; deliver to later phases this frame
        or      CHG_PLAYERY + CHG_CLEARMASK + CHG_PLAYERX + CHG_CURPIECEINDEX + CHG_CURROTATION + CHG_NEXTPIECEINDEX
        ld      (Raised0),a
        ld      a,(Raised1)          ; deliver to later phases this frame
        or      CHG_BOARDROWS + CHG_BOARDRED + CHG_BOARDGREEN + CHG_BOARDBLUE
        ld      (Raised1),a
        ld      a,(Next2)            ; a consumer already ran: defer to next frame
        or      CHG_CURRENTCARD
        ld      (Next2),a
        ret

; --- logic block FinishClear ---
.routine
Glim_FinishClear:
    xor a
    ld (ClearMask),a
    call ClearFullRows   ; A = rows collapsed (the flashed ones)
    ld b,a
    ld a,(LinesCleared)
    add a,b
    ld (LinesCleared),a
    ld a,b
    call ScoreForClears  ; DE = delta
    ld hl,(Score)
    add hl,de
    ld (Score),hl
    call SpawnPiece
    jr nc,_done
    ld a,Card.GameOver
    ld (CurrentCard),a
_done:
        ld      a,(Raised0)          ; deliver to later phases this frame
        or      CHG_CLEARMASK + CHG_LINESCLEARED + CHG_PLAYERX + CHG_PLAYERY + CHG_CURPIECEINDEX + CHG_CURROTATION + CHG_NEXTPIECEINDEX
        ld      (Raised0),a
        ld      a,(Raised1)          ; deliver to later phases this frame
        or      CHG_BOARDROWS + CHG_BOARDRED + CHG_BOARDGREEN + CHG_BOARDBLUE
        ld      (Raised1),a
        ld      a,(Next0)            ; a consumer already ran: defer to next frame
        or      CHG_SCORE
        ld      (Next0),a
        ld      a,(Next2)            ; a consumer already ran: defer to next frame
        or      CHG_CURRENTCARD
        ld      (Next2),a
        ret

; --- derive block DifficultyCurve ---
.routine
Glim_DifficultyCurve:
    ld hl,(Score)
    ld de,2000
    or a
    sbc hl,de
    jr c,_keep
    ld a,16              ; past 2000: twice the pace
    ld (Gravity),a
_keep:
        ret

; --- logic block Pause ---
.routine
Glim_Pause:
        ld      a,Card.Paused      ; goto Paused
        ld      (CurrentCard),a
        ld      a,(Next2)            ; a consumer already ran: defer to next frame
        or      CHG_CURRENTCARD
        ld      (Next2),a
        ret

; --- render block DrawBoard ---
.routine
Glim_DrawBoard:
    call DrawBoardFb
        ret

; --- render block DrawScore ---
.routine
Glim_DrawScore:
    ld hl,(Score)
    call HudWriteU16
        ret

; --- enter block PausedShow ---
.routine
Glim_PausedShow:
    lcd_row MsgPause, LcdRow1
        ret

; --- logic block Unpause ---
.routine
Glim_Unpause:
    lcd_row MsgRun, LcdRow1
        ld      a,Card.Playing      ; goto Playing
        ld      (CurrentCard),a
        ld      a,(Next2)            ; a consumer already ran: defer to next frame
        or      CHG_CURRENTCARD
        ld      (Next2),a
        ret

; --- enter block GameOverShow ---
.routine
Glim_GameOverShow:
    lcd_row MsgOver, LcdRow1
    call Snd_Over
    xor a
    ld (Armed),a         ; close the gate
    ld hl,384            ; corpus GOverGateTicks: arm the once timer
    ld (GOverGate),hl
        ld      a,(Raised1)          ; deliver to later phases this frame
        or      CHG_ARMED
        ld      (Raised1),a
        ret

; --- logic block OpenGate ---
.routine
Glim_OpenGate:
    lcd_row MsgPress, LcdRow2
    ld a,1
    ld (Armed),a
        ld      a,(Raised1)          ; deliver to later phases this frame
        or      CHG_ARMED
        ld      (Raised1),a
        ret

; --- render block GameOverPulse ---
.routine
Glim_GameOverPulse:
    ; dim red heartbeat over the final board: repaint the board, then
    ; overlay the top row in red on alternating half-second beats
    call DrawBoardFb
    ld a,(FrameCount)
    and %00010000
    jr z,_done
    ld hl,Framebuffer    ; row 0 red byte
    ld (hl),$FF
_done:
        ret

; --- logic block Restart ---
.routine
Glim_Restart:
    ld a,(Armed)
    or a
    jr z,_done
    ld a,Card.Splash
    ld (CurrentCard),a
_done:
        ld      a,(Next2)            ; a consumer already ran: defer to next frame
        or      CHG_CURRENTCARD
        ld      (Next2),a
        ret

; --- frame rollover ---
.routine
GlimEndFrame:
        xor     a
        ld      (MoveLeftP),a
        ld      (MoveRightP),a
        ld      (SoftDropP),a
        ld      (RotateP),a
        ld      (PauseP),a
        ld      (AnyKeyP),a
        ld      (GravityFire),a
        ld      (ClearTick),a
        ld      (GateOpenP),a
        ld      (Raised0),a
        ld      (Raised1),a
        ld      (Raised2),a
        ld      a,(Next0)            ; deferred raises become next frame
        ld      (Changed0),a
        ld      a,(Next1)            ; deferred raises become next frame
        ld      (Changed1),a
        ld      a,(Next2)            ; deferred raises become next frame
        ld      (Changed2),a
        xor     a
        ld      (Next0),a
        ld      (Next1),a
        ld      (Next2),a
        ret

; --- imported AZM modules ---
; Import names resolve program-wide; bytes land here, outside
; every execution path. @ labels are the modules' public API.
        .import "tetro-lib.asm"

; --- sound cues ---
; Non-blocking matrix-profile cues. len is row ticks; div is the
; speaker divider. Starting a cue replaces the currently active cue.
.routine
Snd_Rotate:
        ld      a,24
        ld      c,2
        jp      SndStart

.routine
Snd_Lock:
        ld      a,32
        ld      c,4
        jp      SndStart

.routine
Snd_Clear:
        ld      a,72
        ld      c,2
        jp      SndStart

.routine
Snd_Over:
        ld      a,232
        ld      c,8
        jp      SndStart


; --- matrix8x8 profile library ---

; Scan all 8 rows with fixed dwell, then blank the matrix so
; block work never changes visible row brightness. Sound and the
; seven-segment HUD are serviced once per row (8 ticks per frame).
.routine clobbers A,BC,DE,HL
ScanFrame:
        ld      hl,Framebuffer
        ld      c,%00000001          ; row select mask
_row:
        xor     a
        out     (PortRow),a          ; blank before changing colour data
        ld      a,(hl)
        out     (PortRed),a
        inc     hl
        ld      a,(hl)
        out     (PortGreen),a
        inc     hl
        ld      a,(hl)
        out     (PortBlue),a
        inc     hl
        inc     hl                   ; skip aux byte
        ld      a,c
        out     (PortRow),a          ; enable row
        push    bc
        push    hl
        call    SndService
        call    HudScanDig
        pop     hl
        pop     bc
        ld      b,ScanDwellPeriod
_dwell:
        djnz    _dwell
        rlc     c
        jr      nc,_row      ; carry after 8th rotate
        xor     a
        out     (PortRow),a          ; matrix blank on return
        ret

; Convert x (0-7, 0 = leftmost) to the matrix bit convention.
.routine in A out A clobbers B
MxMask:
        or      a
        ld      b,a
        ld      a,%10000000
        ret     z
_loop:
        srl     a
        djnz    _loop
        ret

; Set one pixel. B = x (0-7), C = y (0-7), A = colour bits
; (COLOR_RED/GREEN/BLUE, OR-combined). ORs into the framebuffer.
.routine in A,B,C clobbers A,B,DE,HL
FbPlot:
        ld      d,a                  ; D = colour bits
        ld      a,c
        add     a,a
        add     a,a                  ; y * 4
        ld      e,a
        ld      a,b
        call    MxMask               ; A = pixel mask
        ld      b,a
        ld      hl,Framebuffer
        ld      a,l
        add     a,e
        ld      l,a
        ld      a,h
        adc     a,0
        ld      h,a
        srl     d
        jr      nc,_green
        ld      a,(hl)
        or      b
        ld      (hl),a
_green:
        inc     hl
        srl     d
        jr      nc,_blue
        ld      a,(hl)
        or      b
        ld      (hl),a
_blue:
        inc     hl
        srl     d
        ret     nc
        ld      a,(hl)
        or      b
        ld      (hl),a
        ret

; Clear the whole framebuffer.
.routine clobbers A,B,HL
FbClear:
        ld      hl,Framebuffer
        ld      b,32
        xor     a
_loop:
        ld      (hl),a
        inc     hl
        djnz    _loop
        ret

; (Re)start a sound cue. A = duration in row ticks (8 per frame),
; C = divider half-period; smaller is higher pitch.
.routine in A,C clobbers A
SndStart:
        ld      (SoundTimer),a
        ld      a,c
        ld      (SndDivReload),a
        ld      (SndDivCount),a
        xor     a
        ld      (SpeakerPort),a
        ret

; Tick the speaker state machine once per row scan.
.routine clobbers A
SndService:
        ld      a,(SoundTimer)
        or      a
        ret     z
        dec     a
        ld      (SoundTimer),a
        jr      nz,_active
        xor     a
        ld      (SpeakerPort),a
        ld      (SndDivCount),a
        ret
_active:
        ld      a,(SndDivCount)
        dec     a
        ld      (SndDivCount),a
        ret     nz
        ld      a,(SndDivReload)
        ld      (SndDivCount),a
        ld      a,(SpeakerPort)
        xor     SpeakerBit
        ld      (SpeakerPort),a
        ret

; Strobe one seven-segment digit and advance the scan index.
.routine clobbers A,BC,DE,HL
HudScanDig:
        ld      a,(HudScanIndex)
        ld      c,a
        ld      a,(SpeakerPort)
        out     (PortDigits),a       ; digits off; keep speaker bit
        ld      a,c
        ld      l,a
        ld      h,0
        ld      de,HudSegBuffer
        add     hl,de
        ld      a,(hl)
        out     (PortSegs),a
        ld      a,c
        ld      l,a
        ld      h,0
        ld      de,HudMaskTbl
        add     hl,de
        ld      a,(hl)
        ld      b,a
        ld      a,(SpeakerPort)
        or      b
        out     (PortDigits),a
        ld      a,c
        inc     a
        cp      6
        jr      c,_save
        xor     a
_save:
        ld      (HudScanIndex),a
        ret

; Zero all six HUD digits.
.routine clobbers A,B,HL
HudBlankDig:
        ld      hl,HudSegBuffer
        ld      b,6
        xor     a
_loop:
        ld      (hl),a
        inc     hl
        djnz    _loop
        ret

; Encode HL as decimal into the HUD: slot 0 shows 0, slots 1-5
; the 10000..1 digits.
.routine in HL out BC,HL clobbers A,DE
HudWriteU16:
        ld      a,(HudGlyphTbl)
        ld      (HudSegBuffer),a
        ld      bc,HudSegBuffer + 1
        ld      de,10000
        call    HudDecDigit
        ld      de,1000
        call    HudDecDigit
        ld      de,100
        call    HudDecDigit
        ld      de,10
        call    HudDecDigit
        ld      de,1
        call    HudDecDigit
        ret

; One decimal place value: count DE out of HL, emit the glyph.
.routine in HL,DE,BC out BC,HL clobbers A,DE
HudDecDigit:
        xor     a
_loop:
        push    af
        ld      a,h
        cp      d
        jr      c,_done
        jr      nz,_sub
        ld      a,l
        cp      e
        jr      c,_done
_sub:
        pop     af
        or      a
        sbc     hl,de
        inc     a
        jr      _loop
_done:
        pop     af
        push    hl
        push    bc
        ld      l,a
        ld      h,0
        ld      de,HudGlyphTbl
        add     hl,de
        ld      a,(hl)
        pop     bc
        ld      (bc),a
        inc     bc
        pop     hl
        ret

; Position the LCD cursor at a row command, then write a string.
op lcd_row(msg imm16, row imm8)
        ld      b,row
        ld      c,ApiCommandToLcd
        rst     $10
        ld      hl,msg
        ld      c,ApiStringToLcd
        rst     $10
end
