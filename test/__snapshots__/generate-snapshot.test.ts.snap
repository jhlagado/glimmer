; --- cards ---
; Exactly one card is active; CurrentCard holds it. Blocks in a
; card's section dispatch only while it is active.
Card              .enum Splash, Playing, Paused, GameOver

; --- state storage ---
PlayerX:          .db 0
PlayerY:          .db 0
