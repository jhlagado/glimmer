exports[`generated output snapshots > trail.glim generates byte-identical output 1`] = `
"; Generated by Glimmer from program Trail.
; Do not edit: regenerate from the Glimmer source.
;
; Register contracts are declared with .routine and checked by
; AZM at strict strength (mon3 register profile) during the
; Glimmer build.

        .org    $4000

; Register contracts are declared with .routine and checked at
; strict strength over this whole generated file.
        .contracts strict

; --- TEC-1G / MON-3 platform ---
ApiScanKeys       .equ 16
ApiRandom         .equ 49   ; A = random byte, destroys B
PortDigits        .equ $01
PortSegs          .equ $02
PortRow           .equ $05
PortRed           .equ $06
PortGreen         .equ $F8
PortBlue          .equ $F9
SpeakerBit        .equ $80
ScanDwellPeriod   .equ 255
COLOR_RED         .equ $01
COLOR_GREEN       .equ $02
COLOR_BLUE        .equ $04
COLOR_YELLOW      .equ COLOR_RED + COLOR_GREEN
COLOR_CYAN        .equ COLOR_GREEN + COLOR_BLUE
COLOR_MAGENTA     .equ COLOR_RED + COLOR_BLUE
COLOR_WHITE       .equ $07

; --- MON-3 key codes ---
KEY_2             .equ $02
KEY_8             .equ $08
KEY_4             .equ $04
KEY_6             .equ $06

; --- change flags ---
CHG_DOTX_BIT      .equ 0
CHG_DOTY_BIT      .equ 1
CHG_TRAIL_BIT     .equ 2
CHG_UP_BIT        .equ 3
CHG_DOWN_BIT      .equ 4
CHG_LEFT_BIT      .equ 5
CHG_RIGHT_BIT     .equ 6
CHG_DOTX          .equ %00000001
CHG_DOTY          .equ %00000010
CHG_TRAIL         .equ %00000100
CHG_UP            .equ %00001000
CHG_DOWN          .equ %00010000
CHG_LEFT          .equ %00100000
CHG_RIGHT         .equ %01000000

; --- block trigger masks ---
GlimDep_MoveUp__B0 .equ CHG_UP
GlimDep_MoveDown__B0 .equ CHG_DOWN
GlimDep_MoveLeft__B0 .equ CHG_LEFT
GlimDep_MoveRight__B0 .equ CHG_RIGHT
GlimDep_StampTrail__B0 .equ CHG_DOTX + CHG_DOTY
GlimDep_DrawTrail__B0 .equ CHG_TRAIL + CHG_DOTX + CHG_DOTY

; --- state storage ---
DotX:             .db 3
DotY:             .db 3
Trail:            .ds 8, 0   ; byte array
Up:               .db 0
Down:             .db 0
Left:             .db 0
Right:            .db 0
Glim_HeldKey:     .db $FF
Glim_HeldCount:   .db 0
Changed0:         .db %00000111   ; flags dispatch tests
Raised0:          .db 0   ; raises for later phases this frame
Next0:            .db 0   ; raises deferred to next frame
Framebuffer:      .ds 32           ; 8 rows x R,G,B,aux
SpeakerPort:      .db 0
SoundTimer:       .db 0
SndDivReload:     .db 0
SndDivCount:      .db 0
HudScanIndex:     .db 0
HudSegBuffer:     .ds 6

; --- HUD data tables ---
HudMaskTbl:
        .db     $20, $10, $08, $04, $02, $01
HudGlyphTbl:
        .db     $EB, $28, $CD, $AD, $2E, $A7, $E7, $29
        .db     $EF, $2F, $6F, $E6, $C3, $EC, $C7, $47

; --- runtime loop ---
Start:
        call    FbClear
        call    HudBlankDig
MainLoop:
        call    ScanFrame            ; show one full frame, then blank
        call    GlimPollBindings     ; game work runs in the blank window
        call    GlimRunLogicEffects
        call    GlimMergeRaised
        call    GlimRunRenderEffects
        call    GlimEndFrame
        jp      MainLoop

; --- input polling (MON-3 _scanKeys) ---
.routine
GlimPollBindings:
        ld      c,ApiScanKeys
        rst     $10
        jr      z,_keydown
        ld      a,$FF                ; no key: disarm autorepeat
        ld      (Glim_HeldKey),a
        ret
_keydown:
        ld      b,a                  ; B = key code (DE unsafe: matrix kbd)
        jr      c,_newpress
        ld      a,(Glim_HeldKey)     ; held: autorepeat armed for this key?
        cp      b
        ret     nz
        ld      a,(Glim_HeldCount)
        dec     a
        ld      (Glim_HeldCount),a
        ret     nz
        ld      a,b
        cp      KEY_2
        jr      nz,_held_Up_KEY_2
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Up),a
        ld      a,(Changed0)
        or      CHG_UP
        ld      (Changed0),a
        ret
_held_Up_KEY_2:
        ld      a,b
        cp      KEY_8
        jr      nz,_held_Down_KEY_8
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Down),a
        ld      a,(Changed0)
        or      CHG_DOWN
        ld      (Changed0),a
        ret
_held_Down_KEY_8:
        ld      a,b
        cp      KEY_4
        jr      nz,_held_Left_KEY_4
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Left),a
        ld      a,(Changed0)
        or      CHG_LEFT
        ld      (Changed0),a
        ret
_held_Left_KEY_4:
        ld      a,b
        cp      KEY_6
        jr      nz,_held_Right_KEY_6
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Right),a
        ld      a,(Changed0)
        or      CHG_RIGHT
        ld      (Changed0),a
        ret
_held_Right_KEY_6:
        ret
_newpress:
        ld      a,b
        cp      KEY_2
        jr      nz,_new_Up_KEY_2
        ld      a,b                  ; arm autorepeat
        ld      (Glim_HeldKey),a
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Up),a
        ld      a,(Changed0)
        or      CHG_UP
        ld      (Changed0),a
        ret
_new_Up_KEY_2:
        ld      a,b
        cp      KEY_8
        jr      nz,_new_Down_KEY_8
        ld      a,b                  ; arm autorepeat
        ld      (Glim_HeldKey),a
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Down),a
        ld      a,(Changed0)
        or      CHG_DOWN
        ld      (Changed0),a
        ret
_new_Down_KEY_8:
        ld      a,b
        cp      KEY_4
        jr      nz,_new_Left_KEY_4
        ld      a,b                  ; arm autorepeat
        ld      (Glim_HeldKey),a
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Left),a
        ld      a,(Changed0)
        or      CHG_LEFT
        ld      (Changed0),a
        ret
_new_Left_KEY_4:
        ld      a,b
        cp      KEY_6
        jr      nz,_new_Right_KEY_6
        ld      a,b                  ; arm autorepeat
        ld      (Glim_HeldKey),a
        ld      a,8
        ld      (Glim_HeldCount),a
        ld      a,1
        ld      (Right),a
        ld      a,(Changed0)
        or      CHG_RIGHT
        ld      (Changed0),a
        ret
_new_Right_KEY_6:
        ret

; --- logic phase dispatch ---
.routine
GlimRunLogicEffects:
        ld      a,(Changed0)
        and     GlimDep_MoveUp__B0
        jr      z,_skip_MoveUp
        call    Glim_MoveUp
_skip_MoveUp:
        ld      a,(Changed0)
        and     GlimDep_MoveDown__B0
        jr      z,_skip_MoveDown
        call    Glim_MoveDown
_skip_MoveDown:
        ld      a,(Changed0)
        and     GlimDep_MoveLeft__B0
        jr      z,_skip_MoveLeft
        call    Glim_MoveLeft
_skip_MoveLeft:
        ld      a,(Changed0)
        and     GlimDep_MoveRight__B0
        jr      z,_skip_MoveRight
        call    Glim_MoveRight
_skip_MoveRight:
        ld      a,(Changed0)
        and     GlimDep_StampTrail__B0
        jr      z,_skip_StampTrail
        call    Glim_StampTrail
_skip_StampTrail:
        ret

; --- render phase dispatch ---
.routine
GlimRunRenderEffects:
        ld      a,(Changed0)
        and     GlimDep_DrawTrail__B0
        jr      z,_skip_DrawTrail
        call    Glim_DrawTrail
_skip_DrawTrail:
        ret

; --- phase boundary: deliver same-frame raises ---
.routine
GlimMergeRaised:
        ld      a,(Changed0)
        ld      b,a
        ld      a,(Raised0)
        or      b
        ld      (Changed0),a
        xor     a
        ld      (Raised0),a
        ret

; --- logic block MoveUp ---
.routine
Glim_MoveUp:
    ld a,(DotY)
    or a
    jr z,_stop
    dec a
    ld (DotY),a
_stop:
        ld      a,(Next0)            ; a consumer already ran: defer to next frame
        or      CHG_DOTY
        ld      (Next0),a
        ret

; --- logic block MoveDown ---
.routine
Glim_MoveDown:
    ld a,(DotY)
    cp 7
    jr nc,_stop
    inc a
    ld (DotY),a
_stop:
        ld      a,(Next0)            ; a consumer already ran: defer to next frame
        or      CHG_DOTY
        ld      (Next0),a
        ret

; --- logic block MoveLeft ---
.routine
Glim_MoveLeft:
    ld a,(DotX)
    or a
    jr z,_stop
    dec a
    ld (DotX),a
_stop:
        ld      a,(Next0)            ; a consumer already ran: defer to next frame
        or      CHG_DOTX
        ld      (Next0),a
        ret

; --- logic block MoveRight ---
.routine
Glim_MoveRight:
    ld a,(DotX)
    cp 7
    jr nc,_stop
    inc a
    ld (DotX),a
_stop:
        ld      a,(Next0)            ; a consumer already ran: defer to next frame
        or      CHG_DOTX
        ld      (Next0),a
        ret

; --- logic block StampTrail ---
.routine
Glim_StampTrail:
    ld a,(DotX)
    call MxMask
    ld b,a
    ld a,(DotY)
    ld e,a
    ld d,0
    ld hl,Trail
    add hl,de
    ld a,(hl)
    or b
    ld (hl),a
        ld      a,(Raised0)          ; deliver to later phases this frame
        or      CHG_TRAIL
        ld      (Raised0),a
        ret

; --- render block DrawTrail ---
.routine
Glim_DrawTrail:
    call FbClear
    ld hl,Trail
    ld de,Framebuffer + 1
    ld b,8
_copy:
    ld a,(hl)
    ld (de),a
    inc hl
    inc de
    inc de
    inc de
    inc de
    djnz _copy
    ld a,(DotX)
    ld b,a
    ld a,(DotY)
    ld c,a
    ld a,COLOR_WHITE
    call FbPlot
        ret

; --- frame rollover ---
.routine
GlimEndFrame:
        xor     a
        ld      (Up),a
        ld      (Down),a
        ld      (Left),a
        ld      (Right),a
        ld      (Raised0),a
        ld      a,(Next0)            ; deferred raises become next frame
        ld      (Changed0),a
        xor     a
        ld      (Next0),a
        ret

; --- matrix8x8 profile library ---

