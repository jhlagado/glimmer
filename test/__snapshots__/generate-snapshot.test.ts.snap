; --- block trigger masks ---
GlimDep_SplashShow__B2 .equ CHG_CURRENTCARD
GlimDep_SplashTwinkle__B2 .equ CHG_FRAMECOUNT
GlimDep_SplashExit__B2 .equ CHG_ANYKEYP
GlimDep_StartRound__B2 .equ CHG_CURRENTCARD
GlimDep_ShowPreview__B0 .equ CHG_NEXTPIECEINDEX
